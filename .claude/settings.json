{
  "model": "claude-sonnet-5",
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(python3 -m triggered_agents:*)",
      "Bash(python3 -m secretary memory:*)",
      "Bash(cd ~/triggered-agents:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Read",
      "Edit",
      "Write",
      "mcp__memory__memory_search",
      "mcp__memory__memory_get",
      "mcp__memory__memory_list"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)"
    ]
  }
}
